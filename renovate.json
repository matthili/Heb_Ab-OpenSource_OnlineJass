{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    "group:monorepos",
    "group:recommended"
  ],
  "labels": ["dependencies"],
  "rangeStrategy": "bump",
  "timezone": "Europe/Vienna",
  "schedule": ["before 6am on monday"],
  "prHourlyLimit": 4,
  "prConcurrentLimit": 10,
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 6am on the first day of the month"]
  },
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security", "dependencies"],
    "schedule": ["at any time"],
    "prCreation": "immediate"
  },
  "packageRules": [
    {
      "description": "Group all minor + patch updates per ecosystem into one PR — weniger Noise",
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "groupName": "all non-major dependencies",
      "groupSlug": "all-minor-patch"
    },
    {
      "description": "Major-Updates immer einzeln, mit Approval-Wunsch",
      "matchUpdateTypes": ["major"],
      "labels": ["dependencies", "major-update"],
      "dependencyDashboardApproval": true
    },
    {
      "description": "Engine + Web sind framework-sensible — Tests müssen sauber durch",
      "matchPackagePatterns": ["^@jass/", "^@tensorflow/", "^react", "^@tanstack/"],
      "minimumReleaseAge": "3 days"
    },
    {
      "description": "Security-Auth-Stack: jede Änderung zügig, aber separater PR",
      "matchPackageNames": [
        "better-auth",
        "@better-auth/expo",
        "argon2",
        "@zxcvbn-ts/core",
        "@zxcvbn-ts/language-common",
        "@zxcvbn-ts/language-de",
        "@zxcvbn-ts/language-en"
      ],
      "groupName": "auth & security",
      "labels": ["security", "dependencies"]
    },
    {
      "description": "Prisma: Client + CLI immer im Gleichschritt updaten",
      "matchPackageNames": ["@prisma/client", "prisma", "@prisma/adapter-pg"],
      "groupName": "prisma"
    }
  ]
}
