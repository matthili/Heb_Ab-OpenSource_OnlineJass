{
  "name": "@jass/web",
  "version": "0.0.0",
  "private": true,
  "description": "Spiel-SPA für Heb ab! — React 19 + Vite 8 + TanStack Router/Query. Lobby, Tisch, Auth-Flows. PWA-Polish kommt mit M11.",
  "type": "module",
  "scripts": {
    "predev": "node ../../scripts/sync-web-cards.mjs",
    "dev": "vite",
    "prebuild": "node ../../scripts/sync-web-cards.mjs",
    "build": "tsc -b --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint src",
    "test": "vitest run --passWithNoTests",
    "test:unit": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@jass/engine": "workspace:*",
    "@jass/ui": "workspace:*",
    "@tanstack/react-query": "^5.100.0",
    "@tanstack/react-router": "^1.170.0",
    "better-auth": "^1.6.11",
    "i18next": "^26.2.0",
    "i18next-browser-languagedetector": "^8.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^16.0.0",
    "socket.io-client": "^4.8.3",
    "zod": "^4.0.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@jass/config": "workspace:*",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/router-plugin": "^1.168.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.7.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.6"
  }
}
