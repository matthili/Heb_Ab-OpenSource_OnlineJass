{
  "extends": "@jass/config/tsconfig/react.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist",
    "types": ["vite/client", "node"],
    "paths": {
      "~/*": ["./src/*"]
    },
    // App, keine Library — keine .d.ts/sourceMap-Generation. Vermeidet
    // den TS2742-Pin-Path-Issue mit pnpm-symlinks bei re-exporten aus
    // better-auth.
    "declaration": false,
    "declarationMap": false,
    "composite": false,
    "noEmit": true
  },
  "include": ["src/**/*", "vite.config.ts", "playwright.config.ts", "e2e/**/*"],
  "exclude": ["dist", "node_modules"]
}
