{
  "name": "@jass/inference",
  "version": "0.0.0",
  "private": true,
  "description": "Heb-ab! Inferenz-Microservice: lädt das NN-Modell, beantwortet POST /predict mit policy/value/argmax-Tripel. Schlank gehalten (Fastify, kein NestJS), damit der Container klein bleibt und der CPU-/Speicher-Footprint ehrlich messbar ist.",
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "build": "tsc -b",
    "dev": "tsx src/server.ts",
    "start": "node dist/server.js",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint src",
    "test": "vitest run --passWithNoTests",
    "test:unit": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@jass/engine": "workspace:*",
    "@tensorflow/tfjs": "^4.22.0",
    "fastify": "^5.0.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "@jass/config": "workspace:*",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^4.1.6",
    "vitest": "^4.1.6"
  }
}
