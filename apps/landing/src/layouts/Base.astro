---
/**
 * Basis-Layout für alle Marketing-Seiten. Enthält Header (mit Theme-Toggle
 * und Sprach-Umschalter), Footer und das vanilla-CSS-Stylesheet.
 * Inhalts-Seiten füllen den `<slot />`.
 *
 * **Zweisprachig**: `lang` ("de" | "en") steuert Nav-/Footer-Labels und das
 * URL-Präfix (`/en/...`). `altHref` ist die URL derselben Seite in der jeweils
 * anderen Sprache — Ziel des DE|EN-Umschalters. DE-Seiten leben unter `/`,
 * EN-Seiten unter `/en/`.
 *
 * **Theme**: identische Mechanik wie die Spiel-SPA — localStorage-Key
 * `jass-theme` (`dark` | `hi-contrast`, sonst hell), `data-theme` auf <html>.
 * Das Inline-Script läuft VOR dem ersten Paint (kein Flash); der Toggle
 * zykelt hell → dunkel → hoher Kontrast → hell. Toggle-Labels folgen der
 * Seitensprache (gelesen aus `document.documentElement.lang`).
 */
import "../styles.css";

type Lang = "de" | "en";

interface Props {
  title: string;
  description?: string;
  lang?: Lang;
  /** URL derselben Seite in der anderen Sprache (für den DE|EN-Umschalter). */
  altHref: string;
}
const { title, description, lang = "de", altHref } = Astro.props;

const STRINGS = {
  de: {
    home: "/",
    rules: "/rules",
    about: "/about",
    privacy: "/privacy",
    imprint: "/imprint",
    app: "/app/",
    navRules: "Jassen lernen",
    navAbout: "Über",
    navCta: "Zum Spiel",
    footPrivacy: "Datenschutz",
    footImprint: "Impressum",
    switchLabel: "EN",
    switchTitle: "Switch to English",
    themeAria: "Farbschema wechseln",
  },
  en: {
    home: "/en/",
    rules: "/en/rules",
    about: "/en/about",
    privacy: "/en/privacy",
    imprint: "/en/imprint",
    app: "/app/",
    navRules: "Learn to Jass",
    navAbout: "About",
    navCta: "Play now",
    footPrivacy: "Privacy",
    footImprint: "Imprint",
    switchLabel: "DE",
    switchTitle: "Auf Deutsch wechseln",
    themeAria: "Switch color theme",
  },
} as const;
const s = STRINGS[lang];

// Aktiver Nav-Link (Veronika G1): aktuelle Seite in der Navigation
// hervorheben. Astro liefert den Pfad je nach Seite mit/ohne Trailing-Slash
// → vor dem Vergleich normalisieren.
const norm = (p: string) => p.replace(/\/+$/, "") || "/";
const path = norm(Astro.url.pathname);
const isActive = (href: string) => path === norm(href);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#f0e6cf" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <!-- Theme VOR dem ersten Paint (kein Flash). Externe Datei statt inline,
         damit die strenge CSP (script-src 'self', kein 'unsafe-inline') es erlaubt. -->
    <script is:inline src="/theme-init.js"></script>
  </head>
  <body>
    <div class="page">
      <header class="nav">
        <nav class="nav-inner">
          <a href={s.home} class="nav-brand" aria-label="Heb ab!">
            <img src="/logo/lockup-horizontal-hell.svg" alt="Heb ab!" class="brand-light" />
            <img src="/logo/lockup-horizontal-dunkel.svg" alt="" class="brand-dark" />
          </a>
          <div class="nav-right">
            <a
              href={s.rules}
              class:list={["nav-link", { active: isActive(s.rules) }]}
              aria-current={isActive(s.rules) ? "page" : undefined}
              >{s.navRules}</a
            >
            <a
              href={s.about}
              class:list={["nav-link", { active: isActive(s.about) }]}
              aria-current={isActive(s.about) ? "page" : undefined}
              >{s.navAbout}</a
            >
            <a href={altHref} class="nav-link lang-switch" title={s.switchTitle}>{s.switchLabel}</a>
            <button type="button" id="theme-toggle" class="theme-toggle" aria-label={s.themeAria}
              >◐</button
            >
            <a href={s.app} class="nav-cta">{s.navCta}</a>
          </div>
        </nav>
      </header>
      <main class="main">
        <slot />
      </main>
      <footer class="footer">
        <div class="footer-inner">
          <a href={s.privacy} class="nav-link">{s.footPrivacy}</a>
          <a href={s.imprint} class="nav-link">{s.footImprint}</a>
        </div>
      </footer>
    </div>
    <!-- Theme-Toggle: extern statt inline wegen der strengen CSP (siehe /theme-init.js). -->
    <script is:inline src="/theme-toggle.js" defer></script>
  </body>
</html>
