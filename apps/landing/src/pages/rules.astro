---
/**
 * Die Jass-Schule — umfassende, bebilderte und animierte Anleitung zum
 * Vorarlberger Jassen, von den Karten bis zur Plattform-Bedienung.
 *
 * Fachliche Quelle ist die Spiel-Engine (`packages/engine`): Punktwerte,
 * Trumpf-Ordnung, Legal-Move-Regeln (Farbzwang, Buur-Ausnahme, kein
 * Untertrumpfen), Weis-Werte und Bodensee-Aufbau sind 1:1 von dort
 * übernommen — die Seite erzählt also exakt die Regeln, die der Server
 * durchsetzt. Karten-Bilder: echtes Karten-Set aus `/cards/` (Sync-Script).
 */
import Base from "../layouts/Base.astro";
import PlayingCard from "../components/school/PlayingCard.astro";
import TrickDemo from "../components/school/TrickDemo.astro";
import HandChoiceDemo from "../components/school/HandChoiceDemo.astro";

const TOC = [
  ["karten", "Die Karten"],
  ["punkte", "Punktwerte"],
  ["stich", "Der Stich"],
  ["trumpf", "Trumpf"],
  ["bedienen", "Bedien-Regeln"],
  ["taktik", "Team-Taktik"],
  ["ansagen", "Ansagearten"],
  ["weisen", "Weisen"],
  ["spielarten", "Die 3 Spielarten"],
  ["tisch", "Tisch eröffnen"],
  ["plattform", "Die Plattform"],
] as const;

const SUITS = [
  { id: "eichel", name: "Eichel" },
  { id: "schelle", name: "Schelle" },
  { id: "herz", name: "Herz" },
  { id: "laub", name: "Laub" },
] as const;

/** Punktwerte je Karte — aus packages/engine/src/types.ts. */
const POINTS: Array<[string, string, string, string]> = [
  ["Ass", "11", "11", "11"],
  ["König", "4", "4", "4"],
  ["Ober", "3", "3", "3"],
  ["Unter", "2", "20 — der Buur!", "2"],
  ["Zehn", "10", "10", "10"],
  ["Neun", "0", "14 — das Nell!", "0"],
  ["Acht", "0", "0", "8"],
  ["Sieben", "0", "0", "0"],
  ["Sechs", "0", "0", "0"],
];

/** Trumpf-Stichordnung (stärkste zuerst) — TRUMP_RANK_ORDER der Engine. */
const TRUMP_ORDER = [
  { card: "eichel-U", label: "Buur", pts: "20" },
  { card: "eichel-9", label: "Nell", pts: "14" },
  { card: "eichel-A", label: "Ass", pts: "11" },
  { card: "eichel-K", label: "König", pts: "4" },
  { card: "eichel-O", label: "Ober", pts: "3" },
  { card: "eichel-10", label: "Zehn", pts: "10" },
  { card: "eichel-8", label: "Acht", pts: "0" },
  { card: "eichel-7", label: "Sieben", pts: "0" },
  { card: "eichel-6", label: "Sechs", pts: "0" },
];

const MODES = [
  {
    icon: "/cards/suits/eichel.png",
    title: "Trumpf",
    text: "Eine Farbe sticht alle anderen. In der Trumpf-Farbe regieren Buur (20 Punkte) und Nell (14).",
  },
  {
    icon: "/cards/suits/eichel_gumpf.png",
    title: "Gumpf",
    text: "Die Königsdisziplin: Die Trumpf-Farbe spielt normal (mit Buur & Nell) — in allen anderen Farben gewinnt die tiefste Karte.",
  },
  {
    icon: "/cards/suits/bock.png",
    title: "Oben (Bock)",
    text: "Kein Trumpf — die höchste Karte der angespielten Farbe gewinnt. Die Achter zählen je 8 Punkte.",
  },
  {
    icon: "/cards/suits/geiss.png",
    title: "Unten (Geiß)",
    text: "Kein Trumpf — die tiefste Karte gewinnt. Das Ass ist zum Stechen wertlos, seine 11 Punkte zählen trotzdem. Achter zählen 8.",
  },
  {
    icon: "/cards/suits/slalom.png",
    title: "Slalom",
    text: "Stich für Stich im Wechsel Oben ↔ Unten. Mit welcher Richtung es losgeht, entscheidet die Ansage.",
  },
] as const;

/** Weis-Werte — aus packages/engine/src/weisen.ts. */
const WEIS_ROWS: Array<[string, string, string]> = [
  ["Dreiblatt", "3 aufeinanderfolgende Karten derselben Farbe", "20"],
  ["Vierblatt", "4 aufeinanderfolgende Karten derselben Farbe", "50"],
  ["Fünfblatt", "5 aufeinanderfolgende Karten derselben Farbe", "100"],
  ["Sechs und mehr", "6+ aufeinanderfolgende Karten derselben Farbe", "120"],
  ["Vier Gleiche (10/O/K/A)", "z.B. alle vier Könige", "100"],
  ["Vier Nell", "alle vier Neuner", "150"],
  ["Vier Buur", "alle vier Unter", "200"],
];

const FEATURES = [
  {
    icon: "🪑",
    title: "Lobby & Tische",
    text: "Tische eröffnen, beitreten (offen, auf Anfrage oder nur per Einladung) — freie Plätze füllt auf Wunsch die KI.",
  },
  {
    icon: "🤖",
    title: "KI-Mitspieler",
    text: "Drei Stärken: Zufall (zum Üben), solide Heuristik und ein trainiertes neuronales Netz als stärkster Gegner.",
  },
  {
    icon: "💬",
    title: "Chats",
    text: "Lobby-Chat für alle, Tisch-Chat ab der Warte-Phase (lebt im Spiel weiter) und private Unterhaltungen.",
  },
  {
    icon: "✉️",
    title: "Privatnachrichten",
    text: "Namen anklicken → Privatnachricht. Wer dir schreiben darf, bestimmst du: alle oder nur Freunde; einzelne Personen lassen sich sperren.",
  },
  {
    icon: "🤝",
    title: "Freunde",
    text: "Anfragen, annehmen, entfreunden — und an Geburtstagen erinnert dich die Lobby ans Gratulieren.",
  },
  {
    icon: "🟢",
    title: "Präsenz & Pause",
    text: "Vier Status am Namenspunkt: grün online, blau am Tisch, orange abwesend (AFK-Knopf), grau offline mit „zuletzt gesehen“.",
  },
  {
    icon: "🎬",
    title: "Replays",
    text: "Jede Partie lässt sich Zug für Zug nachspielen — inklusive Weis-Ansagen. Auf Wunsch öffentlich teilbar per Link.",
  },
  {
    icon: "📊",
    title: "Statistik & Leaderboard",
    text: "Partien, Siege, Quoten pro Spielart im Profil; das öffentliche Leaderboard ist strikt Opt-in.",
  },
  {
    icon: "🛡️",
    title: "Privatsphäre",
    text: "Jedes Profilfeld einzeln sichtbar für: alle, Eingeloggte, Freunde oder niemanden. Gilt auch für Online-Status und Statistik.",
  },
  {
    icon: "🚨",
    title: "Melden & Moderation",
    text: "Übergriffiges Verhalten direkt am Namen melden; Admins prüfen jeden Fall. Dazu Wortfilter im Chat.",
  },
  {
    icon: "🔔",
    title: "Nichts verpassen",
    text: "Browser-Push bei Beitritts-Anfragen, Hinweis bei neuen Nachrichten, Wiedereinstieg nach Verbindungsabbruch.",
  },
  {
    icon: "🌗",
    title: "Komfort",
    text: "Deutsch & Englisch, helles, dunkles und kontrastreiches Design, installierbar als App (PWA).",
  },
] as const;
---

<Base
  title="Jassen lernen — die Jass-Schule von Heb ab!"
  description="Vorarlberger Jassen von Grund auf: Karten, Punkte, Trumpf, Farbzwang, Weisen, Kreuz-/Solo-/Bodensee-Jass — bebildert, animiert und mit Plattform-Anleitung."
>
  <article class="school">
    <header class="intro">
      <h1>Die Jass-Schule</h1>
      <p class="lead">
        Vom ersten Blick auf die Karten bis zur fertigen Partie: Hier lernst du das Vorarlberger
        Jassen Schritt für Schritt — mit echten Karten, animierten Beispielen und allem, was die
        Plattform kann. Vorkenntnisse braucht es keine.
      </p>
      <img
        src="/cards/overview/alle-karten.png"
        alt="Alle 36 Jasskarten des Heb-ab!-Decks in der Übersicht"
        class="deck-overview"
        loading="lazy"
        decoding="async"
      />
    </header>

    <nav class="toc" aria-label="Kapitel">
      {TOC.map(([id, label], i) => <a href={`#${id}`}>{i + 1}. {label}</a>)}
    </nav>

    <!-- ───────────────────────── 1 · Die Karten ───────────────────── -->
    <section class="lesson" id="karten">
      <h2><span class="num">1</span>Die Karten</h2>
      <p>
        Gejasst wird mit <strong>36 Karten</strong>: vier Farben zu je neun Karten. Die Reihenfolge
        innerhalb einer Farbe, von schwach nach stark:
        <strong>6 · 7 · 8 · 9 · 10 · Unter · Ober · König · Ass</strong>.
      </p>
      <div class="suit-grid">
        {
          SUITS.map((s) => (
            <figure class="suit">
              <img src={`/cards/suits/${s.id}.png`} alt="" width="40" height="40" />
              <figcaption>{s.name}</figcaption>
              <img
                src={`/cards/overview/${s.id}.png`}
                alt={`Alle neun ${s.name}-Karten`}
                class="suit-overview"
                loading="lazy"
                decoding="async"
              />
            </figure>
          ))
        }
      </div>
      <aside class="note">
        <div class="note-card"><PlayingCard card="schelle-6-weli" w={84} /></div>
        <div>
          <strong>Das WELI</strong> — die Schelle-Sechs trägt ein eigenes Bild und eine besondere
          Rolle: Beim <a href="#spielarten">Bodensee-Jass</a> bestimmt sie, wer die erste Runde
          ansagt, und auf Wunsch, wer ein Folgespiel beginnt. Im Stich selbst ist sie eine ganz
          normale Sechs — kein Joker.
        </div>
      </aside>
    </section>

    <!-- ───────────────────────── 2 · Punktwerte ───────────────────── -->
    <section class="lesson" id="punkte">
      <h2><span class="num">2</span>Punktwerte</h2>
      <p>
        Am Ende jeder Runde zählt jede Seite die Punkte ihrer gewonnenen Stiche. Welche Karte wie
        viel zählt, hängt von der Ansage ab:
      </p>
      <div class="table-wrap">
        <table class="points">
          <thead>
            <tr>
              <th>Karte</th>
              <th>Normale Farbe</th>
              <th>Trumpf-Farbe</th>
              <th>Oben / Unten / Slalom</th>
            </tr>
          </thead>
          <tbody>
            {
              POINTS.map(([k, n, t, ou]) => (
                <tr>
                  <th>{k}</th>
                  <td>{n}</td>
                  <td class={t.includes("—") ? "hot" : ""}>{t}</td>
                  <td class={ou === "8" ? "hot" : ""}>{ou}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
      <ul class="facts">
        <li>
          Der <strong>letzte Stich</strong> bringt <strong>+5</strong> — zusammen also
          <strong>157 Punkte</strong> pro Runde.
        </li>
        <li>
          Gewinnt eine Seite <strong>alle Stiche</strong> („Match"), gibt es <strong>+100</strong> obendrauf.
        </li>
        <li>
          Bei Oben/Unten/Slalom übernehmen die <strong>Achter (je 8 Punkte)</strong> die Rolle der
          fehlenden Trumpf-Punkte.
        </li>
      </ul>
    </section>

    <!-- ───────────────────────── 3 · Der Stich ────────────────────── -->
    <section class="lesson" id="stich">
      <h2><span class="num">3</span>Der Stich</h2>
      <p>
        Reihum legt jede Person <strong>eine Karte</strong>. Wer die stärkste spielt, gewinnt den
        Stich, zieht die Karten zu sich — und spielt zum nächsten Stich an. Die Grundregel:
        <strong>Die höchste Karte der angespielten Farbe gewinnt.</strong>
      </p>
      <TrickDemo
        cards={[
          { card: "herz-K", who: "Anna" },
          { card: "herz-O", who: "Beat" },
          { card: "herz-A", who: "Clara" },
          { card: "herz-7", who: "Du" },
        ]}
        winner={2}
        caption="Herz ist angespielt — Claras Herz-Ass ist die höchste Herz-Karte und gewinnt den Stich."
      />
    </section>

    <!-- ───────────────────────── 4 · Trumpf ───────────────────────── -->
    <section class="lesson" id="trumpf">
      <h2><span class="num">4</span>Trumpf — die Farbe, die alles sticht</h2>
      <p>
        Bei einer Trumpf-Ansage wird eine Farbe zur <strong>Trumpf-Farbe</strong>: Jede ihrer
        Karten schlägt <em>jede</em> Karte der anderen Farben — selbst die kleinste.
      </p>
      <TrickDemo
        cards={[
          { card: "herz-A", who: "Anna" },
          { card: "herz-10", who: "Beat" },
          { card: "schelle-7", who: "Du", note: "Trumpf!" },
          { card: "herz-K", who: "Clara" },
        ]}
        winner={2}
        caption="Schelle ist Trumpf: Deine Schelle-7 sticht sogar das Herz-Ass — Trumpf schlägt jede andere Farbe."
      />
      <p>
        Innerhalb der Trumpf-Farbe gilt eine eigene Rangfolge — ganz oben stehen zwei Karten, die
        sonst unscheinbar sind: der <strong>Unter (Buur)</strong> und die
        <strong>Neun (Nell)</strong>.
      </p>
      <div class="trump-order" role="img" aria-label="Trumpf-Reihenfolge von Buur (stärkste) bis Sechs">
        {
          TRUMP_ORDER.map((t, i) => (
            <div class="to-item">
              <PlayingCard card={t.card} w={54} />
              <span class="to-label">{t.label}</span>
              <span class="to-pts">{t.pts} P.</span>
              {i === 0 && <span class="to-best">stärkste</span>}
            </div>
          ))
        }
      </div>
      <TrickDemo
        cards={[
          { card: "eichel-A", who: "Anna" },
          { card: "eichel-9", who: "Beat", note: "Nell (14)" },
          { card: "eichel-U", who: "Du", note: "Buur (20)" },
          { card: "eichel-K", who: "Clara" },
        ]}
        winner={2}
        caption="Eichel ist Trumpf, alle spielen Trumpf: Der Buur schlägt Nell, Ass und König — er ist die stärkste Karte des Spiels."
      />
    </section>

    <!-- ───────────────────────── 5 · Bedien-Regeln ────────────────── -->
    <section class="lesson" id="bedienen">
      <h2><span class="num">5</span>Bedienen: Farbzwang, Buur-Ausnahme, Untertrumpfen</h2>
      <p>
        Du darfst nicht einfach irgendeine Karte werfen — es gilt <strong>Farbzwang</strong>: Die
        angespielte Farbe muss bedient werden, solange du sie hast. Trumpfen ist (fast) immer
        erlaubt.
      </p>
      <HandChoiceDemo
        trumpSuit="schelle"
        table={[{ card: "herz-O", who: "Anna spielt an" }]}
        hand={[
          { card: "herz-6", ok: true, why: "Herz bedient — immer erlaubt." },
          { card: "schelle-9", ok: true, why: "Trumpfen ist trotz Farbzwang erlaubt." },
          { card: "laub-A", ok: false, why: "Abwerfen verboten — du hast noch Herz!" },
        ]}
        caption="Herz ist angespielt und du hältst noch Herz: bedienen oder trumpfen — aber keine dritte Farbe abwerfen."
      />
      <p>
        Erst wenn du die angespielte Farbe <em>nicht</em> mehr hast, darfst du frei abwerfen oder
        trumpfen. Und es gibt eine berühmte Ausnahme:
        <strong>der Buur muss nie „geopfert" werden.</strong>
      </p>
      <HandChoiceDemo
        trumpSuit="eichel"
        table={[{ card: "eichel-K", who: "Anna spielt Trumpf an" }]}
        hand={[
          { card: "eichel-U", ok: true, why: "Darfst du spielen — musst du aber nicht." },
          { card: "herz-7", ok: true, why: "Erlaubt: dein einziger Trumpf ist der Buur." },
          { card: "laub-9", ok: true, why: "Ebenfalls erlaubt — Buur-Ausnahme." },
        ]}
        caption="Trumpf ist angespielt, dein einziger Trumpf ist der Buur: Du darfst ihn zurückhalten und stattdessen abwerfen."
      />
      <p>
        Die zweite wichtige Beschränkung: <strong>Untertrumpfen ist verboten.</strong> Liegt schon
        ein Trumpf im Stich, darfst du keinen <em>tieferen</em> Trumpf „ohne Not" hineingeben.
      </p>
      <HandChoiceDemo
        trumpSuit="eichel"
        table={[
          { card: "herz-10", who: "Anna spielt an" },
          { card: "eichel-O", who: "Beat trumpft" },
        ]}
        hand={[
          { card: "eichel-U", ok: true, why: "Übertrumpfen ist immer erlaubt." },
          { card: "laub-K", ok: true, why: "Abwerfen ist erlaubt (kein Herz auf der Hand)." },
          { card: "eichel-7", ok: false, why: "Untertrumpfen — verboten, solange du anderes hast." },
        ]}
        caption="Beat hat mit dem Eichel-Ober getrumpft. Dein Eichel-Sieben wäre Untertrumpfen — nur erlaubt, wenn du außer tieferen Trümpfen gar nichts mehr hältst."
      />
    </section>

    <!-- ───────────────────────── 6 · Team-Taktik ──────────────────── -->
    <section class="lesson" id="taktik">
      <h2><span class="num">6</span>Team-Taktik: Schmieren &amp; Stöck</h2>
      <p>
        Beim Kreuz-Jass spielst du im Team. Gewinnt dein Partner den Stich sicher, gibst du ihm
        deine Punktekarten dazu — das heißt <strong>schmieren</strong>. Der Klassiker: dem Partner
        „noch eine Zehn geben".
      </p>
      <TrickDemo
        cards={[
          { card: "herz-6", who: "Gegnerin" },
          { card: "herz-A", who: "Partner" },
          { card: "herz-9", who: "Gegner" },
          { card: "herz-10", who: "Du", note: "+10 geschmiert" },
        ]}
        winner={1}
        caption="Dein Partner gewinnt den Stich sicher mit dem Ass — statt eine wertlose Karte zu werfen, schmierst du ihm die Zehn: 21 Punkte für euer Team."
      />
      <aside class="tip">
        <strong>Stöck:</strong> Hältst du <em>Ober und König der Trumpf-Farbe</em>, sind das die
        „Stöck". Rufe beim Ausspielen der zweiten der beiden Karten <em>„Stöck!"</em> — dann gibt
        es <strong>+20 Punkte</strong>. Ohne Ansage verfallen sie.
      </aside>
    </section>

    <!-- ───────────────────────── 7 · Ansagearten ──────────────────── -->
    <section class="lesson" id="ansagen">
      <h2><span class="num">7</span>Die Ansagearten</h2>
      <p>
        Vor jeder Runde bestimmt die ansagende Person, <em>wie</em> gespielt wird. Beim Kreuz-Jass
        darf sie auch <strong>schieben</strong> — dann muss der Partner ansagen.
      </p>
      <div class="mode-grid">
        {
          MODES.map((m) => (
            <div class="mode">
              <img src={m.icon} alt="" width="44" height="44" loading="lazy" />
              <h3>{m.title}</h3>
              <p>{m.text}</p>
            </div>
          ))
        }
      </div>
      <TrickDemo
        cards={[
          { card: "laub-A", who: "Anna" },
          { card: "laub-9", who: "Beat" },
          { card: "laub-6", who: "Du" },
          { card: "laub-K", who: "Clara" },
        ]}
        winner={2}
        caption="Ansage „Unten“: Die tiefste Karte gewinnt — deine Laub-Sechs sticht das Ass. Dessen 11 Punkte wandern trotzdem in den Stich."
      />
      <TrickDemo
        cards={[
          { card: "herz-A", who: "Anna" },
          { card: "herz-6", who: "Du" },
          { card: "herz-K", who: "Beat" },
          { card: "herz-O", who: "Clara" },
        ]}
        winner={1}
        caption="Gumpf (Trumpf wäre Eichel): In den Nicht-Trumpf-Farben gewinnt wie bei „Unten“ die tiefste Karte — nur die Trumpf-Farbe selbst spielt normal, mit Buur und Nell."
      />
      <div class="slalom-strip" aria-label="Slalom: Richtungswechsel pro Stich">
        <span class="ss-title">
          <img src="/cards/suits/slalom.png" alt="" width="22" height="22" /> Slalom:
        </span>
        <span class="ss-step up">Stich 1 · Oben</span>
        <span class="ss-arrow">→</span>
        <span class="ss-step down">Stich 2 · Unten</span>
        <span class="ss-arrow">→</span>
        <span class="ss-step up">Stich 3 · Oben</span>
        <span class="ss-arrow">→</span>
        <span class="ss-step">… und so weiter</span>
      </div>
      <aside class="note">
        <div>
          <strong>Welche Ansagen sind am Tisch erlaubt?</strong> Das bestimmt, wer den Tisch
          eröffnet — als aufsteigende Leiter: <em>Nur Trumpf</em> →
          <em>+ Oben &amp; Unten (Bock/Geiß)</em> → <em>+ Slalom</em> → <em>Alles (+ Gumpf)</em>.
          Die Stufe gilt für Mensch und KI gleichermaßen.
        </div>
      </aside>
    </section>

    <!-- ───────────────────────── 8 · Weisen ───────────────────────── -->
    <section class="lesson" id="weisen">
      <h2><span class="num">8</span>Weisen — Extra-Punkte für die Hand</h2>
      <p>
        Bestimmte Kartenkombinationen auf der Hand bringen Zusatzpunkte, wenn du sie beim ersten
        Stich <strong>ansagst („weist")</strong>:
      </p>
      <div class="table-wrap">
        <table class="points">
          <thead>
            <tr><th>Weis</th><th>Bedeutung</th><th>Punkte</th></tr>
          </thead>
          <tbody>
            {
              WEIS_ROWS.map(([w, b, p]) => (
                <tr>
                  <th>{w}</th>
                  <td>{b}</td>
                  <td>{p}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
      <p class="example-row">
        Ein Dreiblatt zum Anfassen:
        <span class="mini-cards">
          <PlayingCard card="herz-6" w={46} />
          <PlayingCard card="herz-7" w={46} />
          <PlayingCard card="herz-8" w={46} />
        </span>
        = 20 Punkte. Vierlinge aus Sechsern, Siebnern oder Achtern zählen nicht.
      </p>
      <p>
        Weisen <strong>beide Seiten</strong>, gewinnt der wertvollere Weis — bei Gleichstand
        entscheidet die höhere Karte, dann Trumpf vor Nicht-Trumpf, zuletzt die Vorhand. Nur die
        Gewinnerseite darf <em>alle</em> ihre Weise schreiben.
      </p>
      <aside class="tip">
        <strong>Hausregeln beim Tisch-Eröffnen:</strong> <em>„Weis nur mit Stich"</em> — wer die
        ganze Runde keinen Stich macht, verliert seine Weis-Punkte wieder.
        <em>„Sack (mind. 21)"</em> — wer unter 21 Kartenpunkten bleibt, ist „im Sack": Runden- und
        Weis-Punkte verfallen komplett.
      </aside>
    </section>

    <!-- ───────────────────────── 9 · Spielarten ───────────────────── -->
    <section class="lesson" id="spielarten">
      <h2><span class="num">9</span>Die drei Spielarten von „Heb ab!"</h2>
      <div class="variant-grid">
        <div class="variant">
          <h3>Kreuz-Jass <span class="vsub">zu viert · 2 Teams</span></h3>
          <p>
