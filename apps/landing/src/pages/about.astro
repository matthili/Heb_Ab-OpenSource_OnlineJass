---
/**
 * Über-Seite: erzählt vom Projekt und seinen Überzeugungen — bewusst
 * pseudonym (kein Klarname; die Plattform nimmt Privatsphäre als Default
 * ernst, auch für ihren Autor). Inhaltlich gespeist aus dem echten Stand:
 * Stack-Versionen aus den package.jsons, KI-Aufbau aus README/NN-Projekt.
 */
import Base from "../layouts/Base.astro";
import PlayingCard from "../components/school/PlayingCard.astro";

const PRINCIPLES = [
  {
    icon: "🔓",
    title: "Open Source",
    text: "Der komplette Code ist offen. Karten-Spielen gehört allen — eine Plattform dafür auch.",
  },
  {
    icon: "🏠",
    title: "Selbst hostbar",
    text: "Gedacht für das Familien-NAS, das Vereinsheim oder den Hobby-Server für die Freundesrunde.",
  },
  {
    icon: "⚖️",
    title: "Server-autoritativ",
    text: "Alle Regeln prüft der Server. Was die Jass-Schule erklärt, wird am Tisch durchgesetzt — schummeln ist technisch aussichtslos.",
  },
  {
    icon: "🚫",
    title: "Keine Werbung, kein Tracking",
    text: "Nur technisch notwendige Cookies. Keine Analytics-Drittanbieter, keine Datenverwertung.",
  },
  {
    icon: "🛡️",
    title: "Privatsphäre als Default",
    text: "Jedes Profilfeld, der Online-Status, die Statistik: sichtbar nur für die, die du wählst. Leaderboard strikt Opt-in.",
  },
  {
    icon: "🗣️",
    title: "Mundart im Produkt",
    text: "Buur, Nell, Gumpf, Bock und Geiß, das WELI — die Vorarlberger Begriffe bleiben, wo sie hingehören: im Spiel.",
  },
] as const;

const STACK = [
  {
    area: "Spiel-Client",
    items: "React 19 · Vite 8 · TanStack Router & Query · Tailwind CSS 4 · i18next (DE/EN) · PWA",
  },
  {
    area: "Server",
    items: "NestJS 11 auf Fastify 5 · Socket.IO · Better Auth (Argon2id, Pwned-Passwords-Check)",
  },
  {
    area: "Daten",
    items: "PostgreSQL 16 · Prisma 7 · Redis 7 (Live-State, Präsenz, Locks)",
  },
  {
    area: "Spiel-Engine",
    items: "Eigenes TypeScript-Paket — Regeln, Punkte und Weis-Logik spec-getrieben und testbar",
  },
  {
    area: "KI",
    items: "Training in Python/Keras (Self-Play-Pipeline) · Inferenz als eigener TensorFlow.js-Microservice",
  },
  {
    area: "Drumherum",
    items: "TypeScript überall · pnpm 10 + Turborepo · Vitest + Testcontainers · Docker + Caddy · Astro 6 (diese Seite)",
  },
] as const;

const NUMBERS = [
  ["36", "Karten im Blatt"],
  ["157", "Punkte pro Runde"],
  ["3", "Spielarten"],
  ["18", "Stiche beim Bodensee"],
  ["2", "Sprachen"],
  ["3", "Farbschemata"],
  ["0", "Tracker & Werbung"],
  ["1", "echtes WELI"],
] as const;
---

<Base
  title="Über das Projekt — Heb ab!"
  description="Warum es Heb ab! gibt: Vorarlberger Jass-Kultur als Open-Source-Plattform — selbst hostbar, ohne Tracking, mit eigener Engine, eigenen Karten und trainierter KI."
>
  <article class="about">
    <h1>Über Heb ab!</h1>
    <p class="lead">
      <strong>Heb ab!</strong> ist eine Open-Source-Plattform für den Vorarlberger Jass — gegen
      Menschen, gegen KI oder gemischt. Server-autoritativ, ohne Werbung, ohne Tracking, und so
      gebaut, dass jede und jeder sie selbst betreiben kann.
    </p>

    <section class="sec">
      <h2>Warum „Heb ab!"?</h2>
      <p>
        Wer beim Jassen gibt, lässt vorher <em>abheben</em>: Die Person rechts vom Geber teilt den
        Stapel — oder klopft drauf und lässt ihn ganz. Diese kleine Geste gehört zum Spiel wie der
        Stammtisch zum Wirtshaus; bei uns gibt es sie sogar als zuschaltbare Hausregel („Echtes
        Abheben"). Und dass <em>abheben</em> auch „durchstarten" heißt — das nehmen wir gerne mit.
      </p>
    </section>

    <section class="sec">
      <h2>Warum gibt es das?</h2>
      <p>
        Online-Jass gibt es viele — aber fast immer als Schweizer Schieber. Der
        <strong>Vorarlberger</strong> Jass mit seinen Eigenheiten kommt dabei zu kurz:
        <em>Gumpf</em>, <em>Bock und Geiß</em>, <em>Slalom</em>, das <em>WELI</em>, der
        <em>Bodensee-Jass</em> zu zweit. Heb ab! will genau diese Spielkultur digital erhalten —
        mit denselben Regeln, denselben Begriffen und derselben Sturheit beim Untertrumpf-Verbot
        wie am echten Tisch. Wie das alles funktioniert, zeigt die
        <a href="/rules">Jass-Schule</a>.
      </p>
    </section>

    <section class="sec">
      <h2>Grundsätze</h2>
      <div class="grid">
        {
          PRINCIPLES.map((p) => (
            <div class="tile">
              <span class="t-icon" aria-hidden="true">
                {p.icon}
              </span>
              <h3>{p.title}</h3>
              <p>{p.text}</p>
            </div>
          ))
        }
      </div>
    </section>

    <section class="sec">
      <h2>Eigene Karten, eigene Symbole</h2>
      <p>
        Das komplette Blatt ist eigens für Heb ab! gestaltet — alle 36 Karten, das WELI mit eigenem
        Bild und die Symbole der Ansagearten. Keine Stock-Grafiken, kein fremdes Karten-Deck: Was
        du am Tisch siehst, gibt es nur hier.
      </p>
      <div class="cards-row" aria-hidden="true">
        <div class="cr-fan">
          {
            ["eichel-U", "schelle-9", "herz-A", "schelle-6-weli"].map((c, i) => (
              <div class="cr-card" style={`--i:${i}`}>
                <PlayingCard card={c} w={84} />
              </div>
            ))
          }
        </div>
        <div class="cr-symbols">
          {
            ["eichel", "schelle", "herz", "laub", "bock", "geiss", "slalom"].map((s) => (
              <img src={`/cards/suits/${s}.png`} alt="" width="36" height="36" loading="lazy" />
            ))
          }
        </div>
      </div>
    </section>

    <section class="sec">
      <h2>Die KI am Tisch</h2>
      <p>
        Freie Sitze müssen niemanden aufhalten — sie übernimmt auf Wunsch die KI, in drei Stufen:
        <strong>Zufall</strong> zum lockeren Üben, eine solide <strong>Heuristik</strong> als
        Standard-Gegner, und ein eigens trainiertes <strong>neuronales Netz</strong> als stärkste
        Ausbaustufe. Das Netz lernt in einer Self-Play-Pipeline aus Millionen von Zügen und spielt
        über einen eigenen Inferenz-Dienst mit — und es wird laufend weitertrainiert.
      </p>
    </section>

    <section class="sec">
      <h2>Der Tech-Stack</h2>
      <p>
        Heb ab! ist nebenbei auch eine Tech-Demo: durchgehend aktuelle Major-Versionen, ein
        Monorepo, ein Stack, der zeigt, was sich heute mit offenem Werkzeug bauen lässt.
      </p>
      <div class="stack">
        {
          STACK.map((s) => (
            <div class="stack-row">
              <span class="stack-area">{s.area}</span>
              <span class="stack-items">{s.items}</span>
            </div>
          ))
        }
      </div>
      <p class="ghlink">
        <a href="https://github.com/matthili/vorarlberger_jass_app">Der Code liegt auf GitHub</a> —
        Issues und Pull-Requests sind willkommen.
      </p>
    </section>

    <section class="sec">
      <h2>Zahlen, die wir mögen</h2>
      <div class="numbers">
        {
          NUMBERS.map(([n, label]) => (
            <div class="numtile">
              <span class="num">{n}</span>
              <span class="numlabel">{label}</span>
            </div>
          ))
        }
      </div>
    </section>

    <section class="sec">
      <h2>Wer steckt dahinter?</h2>
      <p>
        Kein Studio, kein Startup — ein einzelner Bastler mit einem Faible für den Vorarlberger
        Jass, im Netz unterwegs als <strong>matthili</strong>. Das Projekt ist bewusst pseudonym:
        Eine Plattform, die Privatsphäre als Standardeinstellung ernst nimmt, darf das auch für
        ihren Autor tun. Wer reden mag, erreicht mich am besten über
        <a href="https://github.com/matthili/vorarlberger_jass_app/issues">GitHub-Issues</a>.
      </p>
      <!--
        Sobald die ViennaTools-Seite online ist, hier einkommentieren:
        <p>Heb ab! ist ein Open-Source-Projekt von <a href="https://…">ViennaTools</a>.</p>
      -->
      <p class="thanks">
        Und ein Dank an die Spielerin der ersten Stunde — sie weiß, wer gemeint ist. 🃏
      </p>
    </section>

    <div class="cta-row">
      <a href="/app/" class="cta">Jetzt mitspielen</a>
      <a href="/rules" class="cta-secondary">Jassen lernen</a>
    </div>
  </article>
</Base>

<style>
  .lead {
    max-width: 42rem;
  }
  .sec {
    margin-top: 2.25rem;
  }
  .sec h2 {
    font-size: 1.35rem;
    border-bottom: 2px solid var(--edge);
    padding-bottom: 0.35rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(14rem, 1fr));
    gap: 0.9rem;
    margin-top: 1rem;
  }
  .tile {
    border: 1px solid var(--edge);
    border-radius: 0.6rem;
    background: var(--card-bg);
    padding: 0.85rem;
  }
  .t-icon {
    font-size: 1.4rem;
  }
  .tile h3 {
    margin: 0.3rem 0 0.2rem;
    font-size: 0.98rem;
  }
  .tile p {
    margin: 0;
    font-size: 0.86rem;
    color: var(--muted);
  }

  /* Karten-Sektion */
  .cards-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
    border: 1px solid var(--edge);
    border-radius: 0.75rem;
    background: var(--card-bg);
    padding: 1.25rem 1rem;
  }
  .cr-fan {
    display: flex;
  }
  .cr-card {
    margin: 0 -0.9rem;
    transform: rotate(calc((var(--i) - 1.5) * 8deg))
      translateY(calc((var(--i) - 1.5) * (var(--i) - 1.5) * 4px));
    transition: transform 0.2s ease;
  }
  .cr-card:hover {
    transform: rotate(calc((var(--i) - 1.5) * 8deg))
      translateY(calc((var(--i) - 1.5) * (var(--i) - 1.5) * 4px - 8px));
    z-index: 2;
  }
  .cr-symbols {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .cr-symbols img {
    display: block;
  }

  /* Stack-Tabelle */
  .stack {
    border: 1px solid var(--edge);
    border-radius: 0.6rem;
    background: var(--card-bg);
    overflow: hidden;
    margin-top: 1rem;
  }
  .stack-row {
    display: grid;
    grid-template-columns: 9rem 1fr;
    gap: 0.75rem;
    padding: 0.55rem 0.85rem;
    font-size: 0.9rem;
  }
  .stack-row + .stack-row {
    border-top: 1px solid var(--edge);
  }
  .stack-area {
    font-weight: 600;
  }
  .stack-items {
    color: var(--muted);
  }
  @media (max-width: 540px) {
    .stack-row {
      grid-template-columns: 1fr;
      gap: 0.15rem;
    }
  }
  .ghlink {
    margin-top: 0.9rem;
  }
  .ghlink a {
    text-decoration: underline;
  }

  /* Zahlen-Kacheln */
  .numbers {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(8.5rem, 1fr));
    gap: 0.7rem;
    margin-top: 1rem;
  }
  .numtile {
    border: 1px solid var(--edge);
    border-radius: 0.6rem;
    background: var(--card-bg);
    padding: 0.75rem 0.5rem;
    text-align: center;
  }
  .num {
    display: block;
    font-size: 1.7rem;
    font-weight: 700;
    color: var(--red);
    line-height: 1.1;
  }
  .numlabel {
    font-size: 0.78rem;
    color: var(--muted);
  }

  .thanks {
    color: var(--muted);
    font-size: 0.95rem;
  }

  .cta-row {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 2.5rem;
  }
</style>
