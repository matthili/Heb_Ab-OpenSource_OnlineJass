---
/**
 * Startseite: Hero-Logo (hell/dunkel je Theme), aufgefächerte echte
 * Jasskarten als Blickfang und zwei Einstiege — direkt spielen oder
 * zuerst die Jass-Schule besuchen.
 */
import Base from "../layouts/Base.astro";
import PlayingCard from "../components/school/PlayingCard.astro";

const FAN = ["eichel-U", "herz-A", "schelle-6-weli", "laub-10", "herz-K"];
---

<Base
  title="Heb ab! — Vorarlberger Kreuz-Jass"
  description="Selbst-hostbare Multiplayer-Plattform für Vorarlberger Kreuz-Jass. Mit echten Spielern, KI-Gegnern und einer Jass-Schule für Einsteiger."
>
  <h1 class="hero-title">
    <img src="/logo/lockup-gestapelt-hell.svg" alt="Heb ab!" class="hero-logo brand-light" />
    <img src="/logo/lockup-gestapelt-dunkel.svg" alt="" class="hero-logo brand-dark" />
  </h1>
  <p class="lead">Der OpenSource-Jass nach vorarlberger Spielart.</p>
  <p>
    Selbst-hostbare Multiplayer-Plattform für Vorarlberger Kreuz-Jass — gegen Menschen, gegen KI,
    oder gemischt. Server-autoritativ, DSGVO-konform, mit echten Karten und echtem WELI.
  </p>
  <div class="fan" aria-hidden="true">
    {
      FAN.map((c, i) => (
        <div class="fan-card" style={`--i:${i}`}>
          <PlayingCard card={c} w={92} />
        </div>
      ))
    }
  </div>
  <p class="cta-row">
    <a href="/app/" class="cta">Jetzt mitspielen</a>
    <a href="/rules" class="cta-secondary">🃏 Jassen lernen</a>
  </p>
  <p class="cta-hint">
    Noch nie gejasst? Die <a href="/rules">Jass-Schule</a> erklärt alles — von der ersten Karte bis
    zur fertigen Partie.
  </p>
</Base>

<style>
  .fan {
    display: flex;
    justify-content: center;
    padding: 1.5rem 0 0.75rem;
  }
  .fan-card {
    margin: 0 -1.1rem;
    transform: rotate(calc((var(--i) - 2) * 9deg)) translateY(calc((var(--i) - 2) * (var(--i) - 2) * 5px));
    opacity: 0;
    animation: fan-in 0.55s cubic-bezier(0.2, 0.7, 0.3, 1.05) forwards;
    animation-delay: calc(var(--i) * 0.12s + 0.2s);
    transition: transform 0.2s ease;
  }
  .fan-card:hover {
    transform: rotate(calc((var(--i) - 2) * 9deg))
      translateY(calc((var(--i) - 2) * (var(--i) - 2) * 5px - 10px));
    z-index: 2;
  }
  @keyframes fan-in {
    from {
      opacity: 0;
      transform: rotate(0deg) translateY(30px);
    }
    to {
      opacity: 1;
      transform: rotate(calc((var(--i) - 2) * 9deg))
        translateY(calc((var(--i) - 2) * (var(--i) - 2) * 5px));
    }
  }
  .cta-row {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    align-items: center;
  }
  .cta-hint {
    font-size: 0.9rem;
    color: var(--muted);
  }
  .cta-hint a {
    text-decoration: underline;
  }
</style>
