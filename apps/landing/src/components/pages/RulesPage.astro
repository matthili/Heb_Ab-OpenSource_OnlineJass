const c = CONTENT[lang];
---

<Base title={c.title} description={c.description} lang={lang} altHref={c.altHref}>
  <article class="school">
    <header class="intro">
      <h1>{c.h1}</h1>
      <p class="lead">{c.lead}</p>
      <img
        src="/cards/overview/alle-karten.png"
        alt={c.deckAlt}
        class="deck-overview"
        loading="lazy"
        decoding="async"
      />
    </header>

    <nav class="toc" aria-label={lang === "en" ? "Chapters" : "Kapitel"}>
      {c.toc.map(([id, label], i) => <a href={`#${id}`}>{i + 1}. {label}</a>)}
    </nav>

    <section class="lesson" id="karten">
      <h2><span class="num">1</span>{c.s1H2}</h2>
      <p set:html={c.s1Intro} />
      <div class="suit-grid">
        {
          SUITS.map((s) => (
            <figure class="suit">
              <img src={`/cards/suits/${s.id}.png`} alt="" width="40" height="40" />
              <figcaption>{s.name}</figcaption>
              <img
                src={`/cards/overview/${s.id}.png`}
                alt={`${c.suitAll} ${s.name}${c.suitOne}`}
                class="suit-overview"
                loading="lazy"
                decoding="async"
              />
            </figure>
          ))
        }
      </div>
      <aside class="note">
        <div class="note-card"><PlayingCard card="schelle-6-weli" w={84} /></div>
        <div set:html={c.weliHtml} />
      </aside>
    </section>

    <section class="lesson" id="punkte">
      <h2><span class="num">2</span>{c.s2H2}</h2>
      <p>{c.s2Intro}</p>
      <div class="table-wrap">
        <table class="points">
          <thead>
            <tr>{c.pointsHead.map((h) => <th>{h}</th>)}</tr>
          </thead>
          <tbody>
            {
              c.pointsRows.map(([k, n, t, ou]) => (
                <tr>
                  <th>{k}</th>
                  <td>{n}</td>
                  <td class={t.includes("—") ? "hot" : ""}>{t}</td>
                  <td class={ou === "8" ? "hot" : ""}>{ou}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
      <ul class="facts">
        {c.facts.map((f) => <li set:html={f} />)}
      </ul>
    </section>

    <section class="lesson" id="stich">
      <h2><span class="num">3</span>{c.s3H2}</h2>
      <p set:html={c.s3Intro} />
      <TrickDemo lang={lang} cards={c.demoStich.cards} winner={c.demoStich.winner} caption={c.demoStich.caption} />
    </section>

    <section class="lesson" id="trumpf">
      <h2><span class="num">4</span>{c.s4H2}</h2>
      <p set:html={c.s4P1} />
      <TrickDemo
        lang={lang}
        cards={c.demoTrumpStich.cards}
        winner={c.demoTrumpStich.winner}
        caption={c.demoTrumpStich.caption}
      />
      <p set:html={c.s4P2} />
      <div class="trump-order" role="img" aria-label={c.s4H2}>
        {
          TRUMP_CARDS.map((t, i) => (
            <div class="to-item">
              <PlayingCard card={t.card} w={54} />
              <span class="to-label">{c.trumpLabels[i]}</span>
              <span class="to-pts">{t.pts} P.</span>
              {i === 0 && <span class="to-best">{c.trumpBest}</span>}
            </div>
          ))
        }
      </div>
      <TrickDemo lang={lang} cards={c.demoBuur.cards} winner={c.demoBuur.winner} caption={c.demoBuur.caption} />
    </section>

    <section class="lesson" id="bedienen">
      <h2><span class="num">5</span>{c.s5H2}</h2>
      <p set:html={c.s5P1} />
      <HandChoiceDemo
        lang={lang}
        trumpSuit={c.demoFarbzwang.trumpSuit}
        table={c.demoFarbzwang.table}
        hand={c.demoFarbzwang.hand}
        caption={c.demoFarbzwang.caption}
      />
      <p set:html={c.s5P2} />
      <HandChoiceDemo
        lang={lang}
        trumpSuit={c.demoBuurEx.trumpSuit}
        table={c.demoBuurEx.table}
        hand={c.demoBuurEx.hand}
        caption={c.demoBuurEx.caption}
      />
      <p set:html={c.s5P3} />
      <HandChoiceDemo
        lang={lang}
        trumpSuit={c.demoUnter.trumpSuit}
        table={c.demoUnter.table}
        hand={c.demoUnter.hand}
        caption={c.demoUnter.caption}
      />
    </section>

