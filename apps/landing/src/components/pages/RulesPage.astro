        ],
      },
      {
        label: "Who may join the table?",
        pills: [{ t: "Open", on: true }, { t: "On request" }, { t: "Invite only" }],
      },
      {
        label: "Which AI fills empty seats?",
        pills: [{ t: "Heuristic", on: true }, { t: "Neural network" }, { t: "Random" }],
      },
      { label: "Auto-fill empty seats", pills: [{ t: "On", on: true }, { t: "Off" }] },
      { label: "Point target of the game", pills: [{ t: "1000", on: true }] },
      {
        label: "Who begins the next game?",
        pills: [{ t: "Winner deals", on: true }, { t: "Play the WELI" }],
      },
      {
        label: "Allowed announcements",
