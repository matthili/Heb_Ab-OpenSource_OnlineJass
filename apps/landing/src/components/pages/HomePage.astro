---
/**
 * Startseite / Home — zweisprachig über `lang`. Hero-Logo (hell/dunkel),
 * aufgefächerte echte Jasskarten und zwei Einstiege (Spielen / Jassen lernen).
 */
import Base from "../../layouts/Base.astro";
import PlayingCard from "../school/PlayingCard.astro";

type Lang = "de" | "en";
interface Props {
  lang?: Lang;
}
const { lang = "de" } = Astro.props;

const FAN = ["eichel-U", "herz-A", "schelle-6-weli", "laub-10", "herz-K"];

interface HomeContent {
  title: string;
  description: string;
  lead: string;
  body: string;
  ctaPlay: string;
  ctaLearn: string;
  hintHtml: string;
  altHref: string;
}

const CONTENT: Record<Lang, HomeContent> = {
  de: {
    title: "Heb ab! — Vorarlberger Kreuz-Jass",
    description:
      "Selbst-hostbare Multiplayer-Plattform für Vorarlberger Kreuz-Jass. Mit echten Spielern, KI-Gegnern und einer Jass-Schule für Einsteiger.",
    lead: "Der OpenSource-Jass nach vorarlberger Spielart.",
    body: "Selbst-hostbare Multiplayer-Plattform für Vorarlberger Kreuz-Jass — gegen Menschen, gegen KI, oder gemischt. Server-autoritativ, DSGVO-konform, mit echten Karten und echtem WELI.",
    ctaPlay: "Jetzt mitspielen",
    ctaLearn: "🃏 Jassen lernen",
    hintHtml:
      'Noch nie gejasst? Die <a href="/rules">Jass-Schule</a> erklärt alles — von der ersten Karte bis zur fertigen Partie.',
    altHref: "/en/",
  },
  en: {
    title: "Heb ab! — Vorarlberg-style Jass",
    description:
      "Self-hostable multiplayer platform for Vorarlberg-style Jass. With real players, AI opponents and a Jass school for beginners.",
    lead: "The open-source Jass, Vorarlberg style.",
    body: "A self-hostable multiplayer platform for Vorarlberg-style Jass — against humans, against AI, or mixed. Server-authoritative, GDPR-compliant, with real cards and a real WELI.",
    ctaPlay: "Play now",
    ctaLearn: "🃏 Learn to Jass",
    hintHtml:
      'Never played Jass? The <a href="/en/rules">Jass school</a> explains it all — from the first card to a finished game.',
    altHref: "/",
  },
};

const c = CONTENT[lang];
---

<Base title={c.title} description={c.description} lang={lang} altHref={c.altHref}>
  <h1 class="hero-title">
    <img src="/logo/lockup-gestapelt-hell.svg" alt="Heb ab!" class="hero-logo brand-light" />
    <img src="/logo/lockup-gestapelt-dunkel.svg" alt="" class="hero-logo brand-dark" />
  </h1>
  <p class="lead">{c.lead}</p>
  <p>{c.body}</p>
  <div class="fan" aria-hidden="true">
    {
      FAN.map((card, i) => (
        <div class="fan-card" style={`--i:${i}`}>
          <PlayingCard card={card} w={92} />
        </div>
      ))
    }
  </div>
  <p class="cta-row">
    <a href="/app/" class="cta">{c.ctaPlay}</a>
    <a href={lang === "en" ? "/en/rules" : "/rules"} class="cta-secondary">{c.ctaLearn}</a>
  </p>
  <p class="cta-hint" set:html={c.hintHtml} />
</Base>

<style>
  .fan {
    display: flex;
    justify-content: center;
    padding: 1.5rem 0 0.75rem;
  }
  .fan-card {
    margin: 0 -1.1rem;
    transform: rotate(calc((var(--i) - 2) * 9deg))
      translateY(calc((var(--i) - 2) * (var(--i) - 2) * 5px));
    opacity: 0;
    animation: fan-in 0.55s cubic-bezier(0.2, 0.7, 0.3, 1.05) forwards;
    animation-delay: calc(var(--i) * 0.12s + 0.2s);
    transition: transform 0.2s ease;
  }
  .fan-card:hover {
    transform: rotate(calc((var(--i) - 2) * 9deg))
      translateY(calc((var(--i) - 2) * (var(--i) - 2) * 5px - 10px));
    z-index: 2;
  }
  @keyframes fan-in {
    from {
      opacity: 0;
      transform: rotate(0deg) translateY(30px);
    }
    to {
      opacity: 1;
      transform: rotate(calc((var(--i) - 2) * 9deg))
        translateY(calc((var(--i) - 2) * (var(--i) - 2) * 5px));
    }
  }
  .cta-row {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    align-items: center;
  }
  .cta-hint {
    font-size: 0.9rem;
    color: var(--muted);
  }
  .cta-hint :global(a) {
    text-decoration: underline;
  }
</style>
