{
  "name": "@jass/api",
  "version": "0.0.0",
  "private": true,
  "description": "NestJS-Backend für Vorarlberger Kreuz-Jass: REST + Socket.IO Gateway, Better Auth, Prisma, server-autoritativer Spielzustand.",
  "type": "module",
  "main": "./dist/main.js",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:watch": "vitest --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.0",
    "@fastify/helmet": "^13.0.0",
    "@jass/engine": "workspace:*",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-fastify": "^11.0.0",
    "@nestjs/platform-socket.io": "^11.1.21",
    "@nestjs/websockets": "^11.1.21",
    "@node-rs/argon2": "^2.0.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "pg": "^8.20.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "better-auth": "^1.6.11",
    "dotenv": "^17.4.2",
    "fastify": "^5.0.0",
    "ioredis": "^5.10.1",
    "nestjs-pino": "^4.4.0",
    "nodemailer": "^8.0.7",
    "pino": "^9.5.0",
    "pino-http": "^10.4.0",
    "pino-pretty": "^13.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "socket.io": "^4.8.3",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@jass/config": "workspace:*",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@swc/core": "^1.15.33",
    "@testcontainers/postgresql": "^11.14.0",
    "@testcontainers/redis": "^11.14.0",
    "@types/node": "^22.10.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.15.5",
    "@vitest/coverage-v8": "^4.1.6",
    "prisma": "^7.8.0",
    "socket.io-client": "^4.8.3",
    "testcontainers": "^11.14.0",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.6"
  }
}
