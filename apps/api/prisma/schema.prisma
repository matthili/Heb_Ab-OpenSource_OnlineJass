// Erlaubte Ansage-Arten pro Tisch (strikte Leiter, jede Stufe erweitert die
// vorige). Siehe @jass/engine `AnnounceLevel` / `announceConstraints`.
//   TRUMPF     — nur Trumpf
//   GEISS_BOCK — + Oben (Bock) / Unten (Geiss)
//   SLALOM     — + Slalom (alterniert Oben/Unten, braucht daher Geiss/Bock)
//   ALLES      — + Gumpf (Default)
enum AnnounceLevel {
  TRUMPF
  GEISS_BOCK
  SLALOM
  ALLES
}

enum ChatChannel {
  LOBBY
  GAME
  // Tisch-weiter Chat (LobbyTable): lebt ab der Warte-Phase und bleibt über
  // Spielstart + Re-Matches erhalten (anders als der spiel-gebundene GAME-Chat).
  TABLE
  DM
}

// ─────────────────────────────────────────────────────────────────────
// Enums — M6 Lobby
// ─────────────────────────────────────────────────────────────────────

enum LobbyTableStatus {
  WAITING // wartet auf Mitspieler
  IN_GAME // Spiel läuft (currentGameId ist gesetzt und nicht finished)
  POST_GAME // letztes Game abgeschlossen, Re-Match-Voting läuft
  MATCH_OVER // kumulative Punkte haben targetScore erreicht — Partie gewonnen
  CLOSED // alle Spieler weg; Tisch verschwindet aus der Lobby-Liste
}

enum JoinMode {
  OPEN // jeder darf joinen
  REQUEST // Owner muss jede Anfrage explizit approve-n
  INVITE // nur eingeladene User können joinen
}

enum RestartMode {
  // Vorarlberger Tradition: zwei Modi für die Starter-Bestimmung beim Re-Match.
  WELI // Karten werden neu ausgeteilt, wer den WELI (Schelle-6) bekommt, beginnt
  SIEGER_GIBT // Sieger gibt, der links davon (im Uhrzeigersinn) kommt raus
}

enum JoinRequestStatus {
  PENDING
  APPROVED
  DENIED
  CANCELLED // Anfragender hat zurückgezogen oder Owner-Wechsel-Auto-Cancel
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED // z.B. wenn der Tisch geschlossen wurde
  CANCELLED // Owner hat die Einladung zurückgezogen
}

enum RematchVoteValue {
  YES
  NO
}
