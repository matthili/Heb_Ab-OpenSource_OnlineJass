{
  "name": "heb-ab",
  "version": "0.0.0",
  "private": true,
  "description": "Heb ab! — der OpenSource-Jass nach vorarlberger Spielart. Selbst-hostbare Multiplayer-Plattform für Vorarlberger Kreuz-Jass mit echten und KI-Gegnern.",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22 <25",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.33.2",
  "jassNn": {
    "version": "v0.5.0",
    "repo": "matthili/jass-neuronales-netz",
    "encodingVersion": "3.0.0",
    "specVersion": "1.1.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:integration": "turbo run test:integration",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\" --ignore-path .gitignore",
    "import:cards": "tsx scripts/import-cards.ts",
    "sync:nn": "tsx scripts/sync-nn.ts",
    "verify:nn": "tsx scripts/verify-nn-manifest.ts",
    "dev:stack": "docker compose -f infra/docker-compose.dev.yml up -d",
    "dev:stack:stop": "docker compose -f infra/docker-compose.dev.yml down",
    "dev:stack:reset": "docker compose -f infra/docker-compose.dev.yml down -v",
    "dev:stack:logs": "docker compose -f infra/docker-compose.dev.yml logs -f",
    "play:smoke": "pnpm --filter @jass/api exec tsx scripts/play-smoke.ts",
    "prepare": "lefthook install || true"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^9.16.0",
    "extract-zip": "^2.0.1",
    "lefthook": "^1.10.0",
    "prettier": "^3.4.0",
    "tsx": "^4.19.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.19.0",
    "vitest": "^4.1.6"
  }
}
