# ─────────────────────────────────────────────────────────────────────
# Vorarlberger Jass App — Beispiel-Umgebungsvariablen
# Kopiere nach `.env` und fülle die Werte aus.
# ─────────────────────────────────────────────────────────────────────

# Allgemein
NODE_ENV=development
APP_NAME=vorarlberger-jass-app
# APP_SECRET: Master-Schlüssel für serverseitige Krypto (SMTP-Passwort-
# Verschlüsselung, CSRF-Tokens etc.). Mindestens 32 Zeichen, kryptografisch
# zufällig — KEINE Placeholder, KEINE repetitiven Muster.
# Generieren (Bash):     openssl rand -base64 48
# Generieren (Node.js):  node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# In production-Builds (NODE_ENV=production) verweigert die App den Boot,
# wenn dieser Wert fehlt, zu kurz oder ein bekannter Placeholder ist.
APP_SECRET=replace-with-output-of-openssl-rand-base64-48-please

# API (apps/api)
API_PORT=3000
API_PUBLIC_URL=http://localhost:3000

# Web (apps/web)
WEB_PORT=5173
WEB_PUBLIC_URL=http://localhost:5173

# Landing (apps/landing)
LANDING_PORT=4321

# Inference (apps/inference)
INFERENCE_PORT=4000
INFERENCE_URL=http://localhost:4000
INFERENCE_MODE=nn          # nn | random  (Fallback-Modus, falls Modell fehlt)

# Postgres
DATABASE_URL=postgresql://jass:jass@localhost:5432/jass?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# SMTP (Default ist Mailhog im Compose-Stack; Produktion via Admin-Panel überschreibbar)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@jass.local

# Auth / Captcha
# BETTER_AUTH_SECRET: Signing-Key für Better-Auth-Sessions. UNABHÄNGIG vom
# APP_SECRET (oben) — wir teilen Schlüssel nicht über Sicherheits-Domänen
# hinweg. Mindestens 32 Zeichen. Boot schlägt fehl, wenn fehlend oder zu kurz.
# Generieren wie APP_SECRET (siehe oben), aber UNTERSCHIEDLICHER Wert.
BETTER_AUTH_SECRET=replace-with-DIFFERENT-output-of-openssl-rand-base64-48
BETTER_AUTH_URL=http://localhost:3000

# Erst-Admin (Bootstrap)
# E-Mail-Adresse des Accounts, der automatisch Admin-Rechte bekommt — löst
# das Henne-Ei-Problem einer frischen Installation (Admin-Rollen vergibt
# sonst nur ein Admin).
#  - Existiert der User bereits  -> Beförderung beim nächsten API-Start.
#  - Registriert er sich danach  -> Beförderung sofort bei der Registrierung.
# Leer lassen, wenn kein Auto-Admin gewünscht ist. Manuell jederzeit über
# `pnpm --filter @jass/api admin:grant <email>`.
ADMIN_EMAIL=

# Cloudflare Turnstile (Captcha gegen Bot-Registrierungen + Mass-Forgot-Spam).
# Erforderlich in production. In dev: ohne diese Werte überspringen wir
# die Captcha-Prüfung lokal — bequem, aber niemals in Production!
# - Setup: https://dash.cloudflare.com → Turnstile → neue Site
# - SECRET_KEY: server-seitig (geheim halten, nicht zum Frontend!)
# - SITE_KEY:   ist im Frontend sichtbar (das ist OK, designed-so)
TURNSTILE_SECRET_KEY=
TURNSTILE_SITE_KEY=
# Für Vite muss derselbe Site-Key zusätzlich mit VITE_-Prefix exportiert
# werden, damit ihn der Web-Build einbettet:
VITE_TURNSTILE_SITE_KEY=

# Sentry (optional in Dev)
SENTRY_DSN=

# NN-Artefakt (wird durch package.json#jassNn.version überschrieben)
JASS_NN_VERSION=v1.0.0
