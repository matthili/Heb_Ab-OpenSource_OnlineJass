# ─────────────────────────────────────────────────────────────────────
# Heb ab! — .env-Vorlage für den ÖFFENTLICHEN Tunnel-Stack
# (infra/docker-compose.tunnel.yml). Kopieren, ausfüllen, starten:
#     cp .env.tunnel.example .env
#     docker compose -f infra/docker-compose.tunnel.yml --env-file .env up -d --build
# Vollständiger Walkthrough (Cloudflare-Tunnel, Verifikation): docs/SELFHOST.md
# ─────────────────────────────────────────────────────────────────────

# ── Frei wählbar ──────────────────────────────────────────────────────
JASS_DOMAIN=jass.example.org
# DB-Passwort — als HEX erzeugen (landet in der DB-URL): openssl rand -hex 24
POSTGRES_PASSWORD=
# E-Mail des Accounts, der automatisch Admin wird — und beim Erst-Setup gleich
# verifiziert, damit du auch bei (noch) nicht laufendem SMTP reinkommst.
ADMIN_EMAIL=du@example.com
# Wohin Ausfall-/Degradierungs-Alarme gemailt werden (darf dieselbe sein):
WATCHDOG_ALERT_EMAIL=du@example.com

# ── Aus dem Cloudflare-Dashboard → Turnstile (Captcha) ────────────────
# Öffentlicher „Site Key" und geheimer „Secret Key" deines Turnstile-Widgets.
VITE_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Vom Mail-Anbieter — SMTP (Pflicht, sonst keine Verifikations-Mails) ─
SMTP_HOST=mail.dein-anbieter.tld
SMTP_PORT=587
SMTP_USER=dein-postfach-login
SMTP_PASSWORD=dein-postfach-passwort
SMTP_FROM=noreply@jass.example.org
# No-Reply-Adresse? leer/true = ja (Hinweis in Mails); false = betreut/überwacht.
SMTP_NO_REPLY=

# APP_SECRET + BETTER_AUTH_SECRET bewusst NICHT setzen — der api-Container
# erzeugt sie beim ersten Start selbst und legt sie auf einem Volume ab.
