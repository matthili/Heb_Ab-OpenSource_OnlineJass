{
  "name": "@jass/engine",
  "version": "0.0.0",
  "private": true,
  "description": "TypeScript-Port der Jass-Engine: Regeln, State, 421-dim Encoder. Pure functions, byte-equivalent zur Python-Referenz im Schwester-Repo.",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./rules": {
      "types": "./dist/src/rules.d.ts",
      "default": "./dist/src/rules.js"
    },
    "./state": {
      "types": "./dist/src/state.d.ts",
      "default": "./dist/src/state.js"
    },
    "./encoder": {
      "types": "./dist/src/encoder.d.ts",
      "default": "./dist/src/encoder.js"
    },
    "./types": {
      "types": "./dist/src/types.d.ts",
      "default": "./dist/src/types.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint src test",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@jass/config": "workspace:*",
    "@vitest/coverage-v8": "^3.2.0",
    "vitest": "^3.2.0"
  }
}
