{
  "name": "@jass/engine",
  "version": "0.0.0",
  "private": true,
  "description": "TypeScript-Port der Jass-Engine: Regeln, State, 132-dim Encoder. Pure functions, byte-equivalent zur Python-Referenz im Schwester-Repo.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./rules": "./src/rules.ts",
    "./state": "./src/state.ts",
    "./encoder": "./src/encoder.ts",
    "./types": "./src/types.ts"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint src test",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@jass/config": "workspace:*",
    "@vitest/coverage-v8": "^3.2.0",
    "vitest": "^3.2.0"
  }
}
