{
  "name": "@jass/ui",
  "version": "0.0.0",
  "private": true,
  "description": "Geteilte React-UI-Komponenten: Card, Hand, Trick, Scoreboard, ChatBubble.",
  "type": "module",
  "main": "./src/index.ts",
